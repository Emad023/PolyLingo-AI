   "source": [
    "def detect_language(audio_path: str) -> str:\n",
    "    \n",
    "    model = WhisperModel(\"tiny\", device=\"cuda\", compute_type=\"float16\")\n",
    "    _, info = model.transcribe(audio_path)\n",
    "    return info.language"
   ]
