    "from langdetect import detect\n",
    "\n",
    "def detect_language(text: str) -> str:\n",
    "    try:\n",
    "        return detect(text)\n",
    "    except Exception as e:\n",
    "        print(f\"Error detecting language: {e}\")\n",
    "        return \"unknown\""
   ]
